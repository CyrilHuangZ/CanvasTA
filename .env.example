# ==============================
# Canvas 基础配置
# ==============================
CANVAS_URL=https://canvas.example.edu
CANVAS_TOKEN=your_canvas_token
COURSE_ID=12345
ASSIGNMENT_ID=67890

# ==============================
# LLM 通用配置（推荐）
# 适用于 OpenAI 官方 / OpenAI 兼容网关 / 多数第三方代理
# 只需要填 KEY 和 BASE_URL 即可
# ==============================
LLM_PROVIDER=auto
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
# 可选：如果你拿到的是完整的 chat/completions URL，可直接填这个
# LLM_API_URL=https://your-gateway/v1/chat/completions

# 常用别名（可二选一）
# OPENAI_API_KEY=your_llm_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# Azure OpenAI（可选）
# 如果填写了 AZURE_OPENAI_ENDPOINT，系统会自动按 Azure 模式请求
# 注意：模型名字段需要填写为 deployment 名称
# ==============================
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-06-01

# ==============================
# 模型与请求参数
# ==============================
VISION_MODEL=qwen2.5-vl-72b-instruct
GRADING_MODEL=gpt-4o-mini
REQUEST_TIMEOUT=180
MAX_VISION_PAGES=10

# ==============================
# 路径配置
# ==============================
DOWNLOAD_DIR=./student_submissions
RESULTS_DIR=./Results
ANSWER_DIR=./Answer
# 建议显式指定标准答案文件
# ANSWER_FILE=./Answer/your_answer.pdf

# ==============================
# 扣分规则
# ==============================
DEDUCTION_RULES=总分100分。一般分数应在85-100；若有重大漏写、少写或关键错误可严重扣分至70。答案正确不扣分；答案错误但步骤/思路正确扣1-2分；答案错误且无步骤扣3-4分。默认仅保留分数记录，overall_comment可为空。

# 是否把评语回传到 Canvas（false=仅回传总分）
RETURN_COMMENT_TO_CANVAS=false

# 题目总数（可选，留空表示不强制）
TOTAL_QUESTIONS=
